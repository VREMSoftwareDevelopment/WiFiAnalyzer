<resources>

    <style name="ThemeBase" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:windowAnimationStyle">@style/WindowAnimationTransition</item>
        <item name="android:windowBackground">@color/background</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@color/surface_container</item>
        <item name="android:actionMenuTextColor">@color/selected</item>
        <item name="colorPrimary">@color/brand_primary</item>
        <item name="colorOnPrimary">@color/brand_on_primary</item>
        <item name="colorPrimaryContainer">@color/brand_primary_container</item>
        <item name="colorOnPrimaryContainer">@color/brand_on_primary_container</item>
        <item name="colorSecondary">@color/channel_number</item>
        <item name="colorTertiary">@color/distance</item>
        <item name="colorSurface">@color/surface_container</item>
        <item name="colorSurfaceVariant">@color/surface_variant</item>
        <item name="colorOnSurface">@color/on_surface</item>
        <item name="colorOnSurfaceVariant">@color/on_surface_variant</item>
        <item name="colorOnBackground">@color/on_surface</item>
        <item name="colorOutline">@color/outline</item>
        <item name="colorError">@color/error</item>
        <item name="toolbarStyle">@style/Widget.WiFiAnalyzer.Toolbar</item>
        <item name="bottomNavigationStyle">@style/Widget.WiFiAnalyzer.BottomNavigationView</item>
        <item name="navigationViewStyle">@style/Widget.WiFiAnalyzer.NavigationView</item>
    </style>

    <style name="ThemeBlack" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:windowAnimationStyle">@style/WindowAnimationTransition</item>
        <item name="android:windowBackground">@color/black</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@color/black</item>
        <item name="android:actionMenuTextColor">@color/selected</item>
        <item name="colorPrimary">@color/brand_primary</item>
        <item name="colorOnPrimary">@color/brand_on_primary</item>
        <item name="colorPrimaryContainer">@color/brand_primary_container</item>
        <item name="colorOnPrimaryContainer">@color/brand_on_primary_container</item>
        <item name="colorSecondary">@color/channel_number</item>
        <item name="colorTertiary">@color/distance</item>
        <item name="colorSurface">@color/black</item>
        <item name="colorSurfaceVariant">#111111</item>
        <item name="colorOnSurface">@android:color/white</item>
        <item name="colorOnSurfaceVariant">#BDBDBD</item>
        <item name="colorOnBackground">@android:color/white</item>
        <item name="colorOutline">#303030</item>
        <item name="colorError">@color/error</item>
        <item name="toolbarStyle">@style/Widget.WiFiAnalyzer.Toolbar</item>
        <item name="bottomNavigationStyle">@style/Widget.WiFiAnalyzer.BottomNavigationView</item>
        <item name="navigationViewStyle">@style/Widget.WiFiAnalyzer.NavigationView</item>
    </style>

    <style name="ThemeBlackNoActionBar" parent="ThemeBlack" />

    <style name="ThemeSystem" parent="ThemeBase" />

    <style name="ThemeSystemNoActionBar" parent="ThemeSystem" />

    <style name="ThemeOverlay" parent="ThemeOverlay.AppCompat.Dark.ActionBar" />

    <style name="ThemeSplash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/background</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/splash_inset</item>
        <item name="windowSplashScreenAnimationDuration">500</item>
    </style>

    <style name="WindowAnimationTransition">
        <item name="android:windowEnterAnimation">@android:anim/fade_in</item>
        <item name="android:windowExitAnimation">@android:anim/fade_out</item>
    </style>

    <style name="Widget.WiFiAnalyzer.Toolbar" parent="Widget.MaterialComponents.Toolbar">
        <item name="android:background">@color/surface_container</item>
        <item name="titleTextColor">@color/on_surface</item>
        <item name="subtitleTextColor">@color/on_surface_variant</item>
        <item name="navigationIconTint">@color/on_surface</item>
        <item name="android:minHeight">64dp</item>
    </style>

    <style name="Widget.WiFiAnalyzer.BottomNavigationView" parent="Widget.MaterialComponents.BottomNavigationView">
        <item name="android:background">@color/surface_container</item>
        <item name="elevation">12dp</item>
        <item name="itemActiveIndicatorStyle">@style/Widget.WiFiAnalyzer.BottomNavigationView.ActiveIndicator</item>
        <item name="itemIconTint">@drawable/menu_selector</item>
        <item name="itemTextColor">@drawable/menu_selector</item>
    </style>

    <style name="Widget.WiFiAnalyzer.BottomNavigationView.ActiveIndicator">
        <item name="android:color">@color/brand_primary_container</item>
        <item name="shapeAppearance">@style/ShapeAppearance.WiFiAnalyzer.NavigationIndicator</item>
    </style>

    <style name="Widget.WiFiAnalyzer.NavigationView" parent="Widget.MaterialComponents.NavigationView">
        <item name="android:background">@color/surface_container</item>
        <item name="elevation">12dp</item>
        <item name="itemBackground">@drawable/navigation_drawer_item_background</item>
        <item name="itemHorizontalPadding">20dp</item>
        <item name="itemIconTint">@drawable/menu_selector</item>
        <item name="itemTextColor">@drawable/menu_selector</item>
    </style>

    <style name="ShapeAppearance.WiFiAnalyzer.NavigationIndicator" parent="ShapeAppearance.MaterialComponents.SmallComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">16dp</item>
    </style>
</resources>
